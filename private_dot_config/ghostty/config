# Ghostty Configuration
# Location: ~/.config/ghostty/config

# Font configuration
font-family = "JetBrainsMono Nerd Font"
font-size = 12
font-thicken = false

# Theme and colors (Catppuccin Mocha)
theme = catppuccin-macchiato

# Window settings
window-decoration = false
window-theme = dark
window-padding-x = 8
window-padding-y = 8

# Terminal behavior
scrollback-limit = 10000
confirm-close-surface = false

# Performance
resize-overlay = never
resize-overlay-position = center
# window-decoration = true

# Shell integration
shell-integration = bash
command = /home/agungtguritno/.bin/dev-session

shell-integration-features = cursor,sudo,title

# HP Laptop optimized keybindings
keybind = ctrl+shift+c=copy_to_clipboard
keybind = ctrl+shift+v=paste_from_clipboard
keybind = ctrl+shift+f=toggle_fullscreen
keybind = ctrl+shift+t=new_tab
keybind = ctrl+shift+w=close_surface
keybind = ctrl+shift+n=new_window

# Tab navigation - FIXED: Use spelled-out number keys
keybind = alt+one=goto_tab:1
keybind = alt+two=goto_tab:2
keybind = alt+three=goto_tab:3
keybind = alt+four=goto_tab:4
keybind = alt+five=goto_tab:5
keybind = ctrl+tab=next_tab
keybind = ctrl+shift+tab=previous_tab

# Pane management (works with tmux)
keybind = ctrl+shift+r=reload_config
